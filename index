          <div class="pipeline-step">
            <div class="pipeline-step-num">5</div>
            <h4>Leaderboard Rank</h4>
            <p>Points influence rank, which helps determine access strength.</p>
          </div>
          <div class="pipeline-step">
            <div class="pipeline-step-num">6</div>
            <h4>Pool Access</h4>
